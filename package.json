{
  "name": "acu-star-database-iii",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "SP·数据库 I (AutoCardUpdater) - SillyTavern 数据库自动更新 Tampermonkey 脚本",
  "scripts": {
    "build": "rollup -c && bash scripts/check-arch.sh",
    "build:nocheck": "rollup -c",
    "build:concat": "BUILD_MODE=concat rollup -c",
    "build:extension": "BUILD_MODE=extension rollup -c",
    "build:all": "BUILD_MODE=all rollup -c",
    "publish:extension": "bash scripts/publish-extension.sh",
    "verify": "bash scripts/verify-build.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/jquery": "^4.0.0",
    "jsdom": "^29.0.2",
    "rollup": "^4.28.0",
    "sql.js": "^1.14.1",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
